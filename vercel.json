{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "buildCommand": "bun run build",
  "redirects": [
    {
      "source": "/",
      "destination": "/swagger",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/swagger",
      "destination": "/swagger.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ]
}
