{
  "name": "ethan-dapp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "build": "bun build ./src/client/index.html --outdir=public --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*' && cp src/server/static/swagger.html public/swagger.html",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "test": "bun test",
    "fmt": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"test/**/*.{ts,tsx}\" \"*.{json,md,yaml}\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "ethers": "^6.17.0",
    "hono": "^4.12.27",
    "jsonwebtoken": "^9.0.3",
    "react": "^19",
    "react-dom": "^19",
    "siwe": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}
